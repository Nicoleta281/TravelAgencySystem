<Window x:Class="TravelAgency.WPF.Views.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:TravelAgency.Core.Models;assembly=TravelAgency.Core"
        xmlns:tripModels="clr-namespace:TravelAgency.Core.Models.TripPkg.Package;assembly=TravelAgency.Core"
        mc:Ignorable="d"
        Title="Client Workspace"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FB">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#183B6B">
            <Grid Margin="0,16,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Logo / Title -->
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,24">
                    <Ellipse Width="68" Height="68" Fill="#3B82F6"/>
                    <TextBlock Text="Travel Agency"
                               Foreground="White"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,16,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Menu -->
                <StackPanel Grid.Row="1" Margin="14,0,14,0">
                    <Button Content="Browse Packages"
        Height="44"
        Margin="0,0,0,12"
        Background="#3B82F6"
        Foreground="White"
        BorderThickness="0"
        FontSize="15"
        FontWeight="SemiBold"
        Command="{Binding ShowPackagesCommand}"/>

                    <Button Content="My Bookings"
        Height="44"
        Margin="0,0,0,12"
        Background="Transparent"
        Foreground="White"
        BorderBrush="Transparent"
        FontSize="15"
        HorizontalContentAlignment="Left"
        Padding="16,0,0,0"
        Command="{Binding ShowBookingsCommand}"/>

                    <Button Content="Favorites"
                            Height="44"
                            Margin="0,0,0,12"
                            Background="Transparent"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="15"
                            HorizontalContentAlignment="Left"
                            Padding="16,0,0,0"/>

                    <Button Content="Profile / Account"
                            Height="44"
                            Margin="0,0,0,12"
                            Background="Transparent"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="15"
                            HorizontalContentAlignment="Left"
                            Padding="16,0,0,0"/>
                    <Button Content="Logout"
        Command="{Binding LogoutCommand}"
        Background="#EF4444"
        Foreground="White"
        Margin="0,20,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="18"
                    Padding="24"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Browse Travel Packages"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#1E2A44"/>
                        <TextBlock Text="Discover and book your perfect trip"
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <TextBox Grid.Column="1"
                             Height="40"
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             Padding="12,0,12,0"
                             Margin="16,0,16,0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Grid.Column="2"
        Content="My Bookings"
        Height="40"
        Background="#3B82F6"
        Foreground="White"
        BorderThickness="0"
        FontWeight="SemiBold"
        FontSize="14"
        Command="{Binding ShowBookingsCommand}"/>
                </Grid>
            </Border>

            <!-- Filters -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="18"
                    Padding="20"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="Destination"
                                   FontSize="14"
                                   Margin="0,0,0,6"
                                   Foreground="#374151"/>
                        <TextBox Height="38"
                                 FontSize="14"
                                 Padding="10,0,10,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Text="Price Range"
                                   FontSize="14"
                                   Margin="0,0,0,6"
                                   Foreground="#374151"/>
                        <ComboBox Height="38"
                                  FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,14,0">
                        <TextBlock Text="Trip Type"
                                   FontSize="14"
                                   Margin="0,0,0,6"
                                   Foreground="#374151"/>
                        <ComboBox Height="38"
                                  FontSize="14"/>
                    </StackPanel>

                    <Button Grid.Column="3"
                            Content="Apply Filters"
                            Height="38"
                            VerticalAlignment="Bottom"
                            Background="#3B82F6"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            FontSize="14"/>
                </Grid>
            </Border>

            <!-- Main Area -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid>
                    <!-- Packages View -->
                    <Grid Visibility="{Binding PackagesVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Available Packages"
                   FontSize="19"
                   FontWeight="Bold"
                   Foreground="#1E2A44"
                   Margin="0,0,0,16"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Packages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type tripModels:TripPackage}">
                                        <Border Width="220"
                                Height="310"
                                Margin="0,0,16,16"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="16">
                                            <StackPanel>
                                                <Border Height="120"
                                        Background="#DCEAFB"
                                        CornerRadius="16,16,0,0"/>

                                                <StackPanel Margin="14">
                                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#1E2A44"
                                               TextWrapping="Wrap"/>

                                                    <TextBlock FontSize="13"
                                               Foreground="#6B7280"
                                               Margin="0,6,0,0">
                                        <Run Text="{Binding TransportDisplayName}"/>
                                        <Run Text=" + "/>
                                        <Run Text="{Binding StayDisplayName}"/>
                                                    </TextBlock>

                                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="13"
                                               Foreground="#6B7280">
                                        <Run Text="Destination: "/>
                                        <Run Text="{Binding Destination}"/>
                                                    </TextBlock>

                                                    <TextBlock Text="{Binding Price, StringFormat=€ {0:F2}}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#1E2A44"
                                               Margin="0,12,0,14"/>

                                                    <Button Content="View Details"
                                            Height="36"
                                            Background="#3B82F6"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            FontSize="13"
                                            Tag="{Binding}"
                                            Click="ViewDetails_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- Bookings View -->
                    <Grid Visibility="{Binding BookingsVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="My Bookings"
                   FontSize="19"
                   FontWeight="Bold"
                   Foreground="#1E2A44"
                   Margin="0,0,0,16"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding MyBookings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,14"
                                Padding="16"
                                Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="14">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TripPackage.Name}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="#1E2A44"/>

                                                <TextBlock Margin="0,8,0,0"
                                           FontSize="14"
                                           Foreground="#374151"
                                           Text="{Binding BookingDate, StringFormat=Booked on: {0:dd MMM yyyy HH:mm}}"/>

                                                <TextBlock Text="{Binding Status.Name}"
           FontSize="16"
           Foreground="#666"
           Margin="0,4,0,0"/>

                                                <TextBlock Margin="0,4,0,0"
                                           FontSize="14"
                                           Foreground="#374151"
                                           Text="{Binding BasePrice, StringFormat=Base Price: € {0:F2}}"/>

                                                <TextBlock Margin="0,4,0,0"
                                           FontSize="14"
                                           Foreground="#374151"
                                           Text="{Binding TotalPrice, StringFormat=Total Price: € {0:F2}}"/>

                                                <ItemsControl ItemsSource="{Binding SelectedExtras}" Margin="0,10,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#E8F0FE"
                                                    CornerRadius="10"
                                                    Padding="8,4"
                                                    Margin="0,0,8,8">
                                                                <TextBlock Text="{Binding}"
                                                           FontSize="12"
                                                           Foreground="#1D4ED8"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- Right Details Panel -->
                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="18"
                        Padding="16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Package Details"
                                       FontSize="19"
                                       FontWeight="Bold"
                                       Foreground="#1E2A44"
                                       Margin="0,0,0,16"/>

                            <Border Height="150"
                                    Background="#DCEAFB"
                                    CornerRadius="14"
                                    Margin="0,0,0,16"/>

                            <TextBlock Text="{Binding SelectedPackage.Name}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#1E2A44"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"/>

                            <TextBlock Margin="0,3,0,0" FontSize="14" Foreground="#374151">
                                <Run Text="Transport: "/>
                                <Run Text="{Binding SelectedPackage.TransportDisplayName}"/>
                            </TextBlock>

                            <TextBlock Margin="0,3,0,0" FontSize="14" Foreground="#374151">
                                <Run Text="Stay: "/>
                                <Run Text="{Binding SelectedPackage.StayDisplayName}"/>
                            </TextBlock>

                            <TextBlock Margin="0,3,0,0" FontSize="14" Foreground="#374151">
                                <Run Text="Destination: "/>
                                <Run Text="{Binding SelectedPackage.Destination}"/>
                            </TextBlock>

                            <TextBlock Margin="0,3,0,0" FontSize="14" Foreground="#374151">
                                <Run Text="Country: "/>
                                <Run Text="{Binding SelectedPackage.Country}"/>
                            </TextBlock>

                            <TextBlock Margin="0,3,0,16" FontSize="14" Foreground="#374151" TextWrapping="Wrap">
                                <Run Text="Description: "/>
                                <Run Text="{Binding SelectedPackage.ShortDescription}"/>
                            </TextBlock>

                            <!-- Extras -->
                            <TextBlock Text="Customize Your Trip"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="#1E2A44"
                                       Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding AvailableExtras}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:OptionalExtra}">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Margin="0,8,0,8"
                                                  FontSize="14"
                                                  Cursor="Hand">
                                            <TextBlock>
                                                <Run Text="{Binding Name}"/>
                                                <Run Text=" (+ €"/>
                                                <Run Text="{Binding Price, StringFormat={}{0:F0}}"/>
                                                <Run Text=")"/>
                                            </TextBlock>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Price Breakdown -->
                            <Border Background="#F9FAFB"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14"
                                    Margin="0,10,0,16">
                                <StackPanel>
                                    <TextBlock Text="Price Breakdown"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#1E2A44"
                                               Margin="0,0,0,12"/>

                                    <Grid Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Base Price" FontSize="14"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding BasePrice, StringFormat=€ {0:F2}}"
                                                   FontSize="14"/>
                                    </Grid>

                                    <Separator Margin="0,12,0,12"/>

                                    <Grid Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Total"
                                                  FontSize="18"
                                                   FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TotalPrice, StringFormat=€ {0:F2}}"
                                                  FontSize="18"
                                                   FontWeight="Bold"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Button Content="Send Request"
        Height="42"
        Background="#3B82F6"
        Foreground="White"
        BorderThickness="0"
        FontSize="15"
        FontWeight="SemiBold"
        Cursor="Hand"
        Command="{Binding ConfirmBookingCommand}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>