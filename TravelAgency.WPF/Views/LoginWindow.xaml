<Window x:Class="TravelAgency.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Login"
        Height="500"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FB">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Border Background="#1E3A6D">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Ellipse Width="100" Height="100" Fill="#3B82F6"/>
                <TextBlock Text="Travel Agency"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Sign in to continue"
                           Foreground="#D6E4FF"
                           FontSize="16"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Border Background="White"
                    CornerRadius="18"
                    Padding="40"
                    Margin="40">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Welcome back"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>

                    <TextBlock Text="Enter your credentials"
                               FontSize="14"
                               Foreground="#6B7280"
                               Margin="0,8,0,25"/>

                    <TextBlock Text="Username"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Height="38"
                             Padding="10"
                             Margin="0,0,0,18"/>

                    <TextBlock Text="Password"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="PasswordInput"
                                 Height="38"
                                 Padding="10"
                                 Margin="0,0,0,20"
                                 PasswordChanged="PasswordInput_PasswordChanged"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#E74C3C"
                               FontSize="13"
                               Margin="0,0,0,15"/>

                    <Button Content="Login"
                            Command="{Binding LoginCommand}"
                            Height="44"
                            Background="#3B82F6"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontWeight="Bold"/>

                    <Button Content="Create account"
        Command="{Binding OpenRegisterCommand}"
        Height="40"
        Margin="0,12,0,0"
        Background="Transparent"
        BorderBrush="#D1D5DB"
        Foreground="#374151"/>
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="Test accounts:"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>
                        <TextBlock Text="Agent: agent1 / Agent123!"
                                   Foreground="#6B7280"
                                   Margin="0,6,0,0"/>
                        <TextBlock Text="Client: client1 / Client123!"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>