<Window x:Class="TravelAgency.WPF.Views.CreatePackageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New Package"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7FB">

    <Grid Margin="24">
        <Border Background="White"
                CornerRadius="18"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Create New Package"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>
                    <TextBlock Text="Fill in the travel package details step by step"
                               FontSize="14"
                               Foreground="#6B7280"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Steps -->
                <Grid Grid.Row="1" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <Border x:Name="Step1Circle" Width="36" Height="36" CornerRadius="18" Background="#2F80ED">
                            <TextBlock Text="1"
                   Foreground="White"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,8,0,0"/>
                        </Border>
                        <TextBlock x:Name="Step1Label"
               Text="Basic Info"
               FontSize="13"
               FontWeight="SemiBold"
               Foreground="#2F80ED"
               Margin="0,8,0,0"
               HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <Border x:Name="Step2Circle" Width="36" Height="36" CornerRadius="18" Background="#E5E7EB">
                            <TextBlock Text="2"
                   Foreground="#6B7280"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,8,0,0"/>
                        </Border>
                        <TextBlock x:Name="Step2Label"
               Text="Destination &amp; Dates"
               FontSize="13"
               Foreground="#6B7280"
               Margin="0,8,0,0"
               HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <Border x:Name="Step3Circle" Width="36" Height="36" CornerRadius="18" Background="#E5E7EB">
                            <TextBlock Text="3"
                   Foreground="#6B7280"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,8,0,0"/>
                        </Border>
                        <TextBlock x:Name="Step3Label"
               Text="Transport &amp; Accommodation"
               FontSize="13"
               Foreground="#6B7280"
               Margin="0,8,0,0"
               HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <Border x:Name="Step4Circle" Width="36" Height="36" CornerRadius="18" Background="#E5E7EB">
                            <TextBlock Text="4"
                   Foreground="#6B7280"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,8,0,0"/>
                        </Border>
                        <TextBlock x:Name="Step4Label"
               Text="Pricing"
               FontSize="13"
               Foreground="#6B7280"
               Margin="0,8,0,0"
               HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                        <Border x:Name="Step5Circle" Width="36" Height="36" CornerRadius="18" Background="#E5E7EB">
                            <TextBlock Text="5"
                   Foreground="#6B7280"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,8,0,0"/>
                        </Border>
                        <TextBlock x:Name="Step5Label"
               Text="Review"
               FontSize="13"
               Foreground="#6B7280"
               Margin="0,8,0,0"
               HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Main content -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Preview card -->
                    <Border Grid.Column="0"
        Background="#FAFBFF"
        BorderBrush="#E5E7EB"
        BorderThickness="1"
        CornerRadius="16"
        Padding="16">
                        <StackPanel>
                            <Border Height="200"
                Background="#DCEBFA"
                CornerRadius="14">
                                <Grid>
                                    <TextBlock x:Name="PreviewDestinationCodeText"
                           Text="PARIS"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1F3A5F"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBlock x:Name="PreviewPackageNameText"
                   Text="Paris Getaway"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#1F2937"
                   Margin="0,16,0,8"/>

                            <TextBlock x:Name="PreviewDescriptionText"
                   Text="Sample preview for the package card"
                   FontSize="14"
                   Foreground="#6B7280"
                   Margin="0,0,0,16"
                   TextWrapping="Wrap"/>

                            <TextBlock x:Name="PreviewTransportStayText"
                   Text="Flight + Hotel"
                   FontSize="14"
                   Foreground="#374151"
                   Margin="0,0,0,8"/>

                            <TextBlock x:Name="PreviewPriceText"
                   Text="€850"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#1F2937"
                   Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Form -->
                    <Border Grid.Column="2"
        Background="White"
        BorderBrush="#E5E7EB"
        BorderThickness="1"
        CornerRadius="16"
        Padding="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="22">
                                <!-- STEP 1 -->
                            <StackPanel x:Name="Step1Panel">
                                <TextBlock Text="Step 1: Basic Info"
               FontSize="24"
               FontWeight="Bold"
               Foreground="#1F2937"
               Margin="0,0,0,18"/>

                                <TextBlock Text="Package Name"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#374151"/>
                                <TextBox x:Name="PackageNameTextBox"
             Height="42"
             Margin="0,8,0,16"
             FontSize="14"
             Padding="12,0"/>

                                <TextBlock Text="Trip Type"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#374151"/>
                                <ComboBox x:Name="TripTypeComboBox"
              Height="42"
              Margin="0,8,0,16"
              FontSize="14">
                                    <ComboBoxItem Content="City Break"/>
                                    <ComboBoxItem Content="Beach Holiday"/>
                                    <ComboBoxItem Content="Adventure"/>
                                    <ComboBoxItem Content="Cultural Tour"/>
                                </ComboBox>

                                <TextBlock Text="Category"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#374151"/>
                                <ComboBox x:Name="CategoryComboBox"
              Height="42"
              Margin="0,8,0,16"
              FontSize="14">
                                    <ComboBoxItem Content="Standard"/>
                                    <ComboBoxItem Content="Premium"/>
                                    <ComboBoxItem Content="Luxury"/>
                                </ComboBox>

                                <TextBlock Text="Short Description"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#374151"/>
                                <TextBox x:Name="ShortDescriptionTextBox"
             Height="120"
             Margin="0,8,0,0"
             FontSize="14"
             TextWrapping="Wrap"
             AcceptsReturn="True"
             VerticalScrollBarVisibility="Auto"
             Padding="12"/>
                            </StackPanel>

                            <!-- STEP 2 -->
                            <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                                <TextBlock Text="Step 2: Destination &amp; Dates"
               FontSize="24"
               FontWeight="Bold"
               Foreground="#1F2937"
               Margin="0,0,0,18"/>

                                <TextBlock Text="Destination"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#374151"/>
                                <TextBox x:Name="DestinationTextBox"
             Height="42"
             Margin="0,8,0,16"
             FontSize="14"
             Padding="12,0"/>

                                <TextBlock Text="Country"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#374151"/>
                                <TextBox x:Name="CountryTextBox"
             Height="42"
             Margin="0,8,0,16"
             FontSize="14"
             Padding="12,0"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Start Date"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <DatePicker x:Name="StartDatePicker"
                        Height="42"
                        Margin="0,8,0,0"
                        FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="End Date"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <DatePicker x:Name="EndDatePicker"
                        Height="42"
                        Margin="0,8,0,0"
                        FontSize="14"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Number of Days"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#374151"/>
                                <TextBox x:Name="NumberOfDaysTextBox"
             Height="42"
             Margin="0,8,0,0"
             FontSize="14"
             Padding="12,0"/>
                            </StackPanel>
                            <!--STEP 3-->
                            <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                                <TextBlock Text="Step 3: Transport &amp; Accommodation"
               FontSize="24"
               FontWeight="Bold"
               Foreground="#1F2937"
               Margin="0,0,0,18"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Transport Type"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <ComboBox x:Name="TransportTypeComboBox"
                      Height="42"
                      Margin="0,8,0,0"
                      FontSize="14">
                                            <ComboBoxItem Content="Flight"/>
                                            <ComboBoxItem Content="Bus"/>
                                            <ComboBoxItem Content="Train"/>
                                            <ComboBoxItem Content="Own Transport"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Departure City"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <TextBox x:Name="DepartureCityTextBox"
                     Height="42"
                     Margin="0,8,0,0"
                     FontSize="14"
                     Padding="12,0"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Accommodation Type"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <ComboBox x:Name="AccommodationTypeComboBox"
                      Height="42"
                      Margin="0,8,0,0"
                      FontSize="14">
                                            <ComboBoxItem Content="Hotel"/>
                                            <ComboBoxItem Content="Resort"/>
                                            <ComboBoxItem Content="Apartment"/>
                                            <ComboBoxItem Content="Villa"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Hotel / Accommodation Name"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <TextBox x:Name="AccommodationNameTextBox"
                     Height="42"
                     Margin="0,8,0,0"
                     FontSize="14"
                     Padding="12,0"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Meal Plan"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <ComboBox x:Name="MealPlanComboBox"
                      Height="42"
                      Margin="0,8,0,0"
                      FontSize="14">
                                            <ComboBoxItem Content="Breakfast"/>
                                            <ComboBoxItem Content="Half Board"/>
                                            <ComboBoxItem Content="Full Board"/>
                                            <ComboBoxItem Content="All Inclusive"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Available Seats"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <TextBox x:Name="AvailableSeatsTextBox"
                     Height="42"
                     Margin="0,8,0,0"
                     FontSize="14"
                     Padding="12,0"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Included Services"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#374151"
               Margin="0,0,0,8"/>

                                <WrapPanel>
                                    <CheckBox x:Name="AirportTransferCheckBox" Content="Airport Transfer" Margin="0,0,18,10" FontSize="14"/>
                                    <CheckBox x:Name="TravelInsuranceCheckBox" Content="Travel Insurance" Margin="0,0,18,10" FontSize="14"/>
                                    <CheckBox x:Name="TourGuideCheckBox" Content="Tour Guide" Margin="0,0,18,10" FontSize="14"/>
                                    <CheckBox x:Name="FreeCancellationCheckBox" Content="Free Cancellation" Margin="0,0,18,10" FontSize="14"/>
                                </WrapPanel>
                            </StackPanel>

                            <!--STEP 4-->
                            <StackPanel x:Name="Step4Panel" Visibility="Collapsed">
                                <TextBlock Text="Step 4: Pricing"
               FontSize="24"
               FontWeight="Bold"
               Foreground="#1F2937"
               Margin="0,0,0,18"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Base Price"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <TextBox x:Name="BasePriceTextBox"
                     Height="42"
                     Margin="0,8,0,0"
                     FontSize="14"
                     Padding="12,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Discount (%)"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <TextBox x:Name="DiscountTextBox"
                     Height="42"
                     Margin="0,8,0,0"
                     FontSize="14"
                     Padding="12,0"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="VAT (%)"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <TextBox x:Name="VatTextBox"
                     Height="42"
                     Margin="0,8,0,0"
                     FontSize="14"
                     Padding="12,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Extra Charges"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#374151"/>
                                        <TextBox x:Name="ExtraChargesTextBox"
                     Height="42"
                     Margin="0,8,0,0"
                     FontSize="14"
                     Padding="12,0"/>
                                    </StackPanel>
                                </Grid>

                                <Border Background="#F3F8FF"
            CornerRadius="14"
            Padding="18"
            Margin="0,10,0,18">
                                    <StackPanel>
                                        <TextBlock Text="Estimated Final Price"
                       FontSize="14"
                       Foreground="#6B7280"/>
                                        <TextBlock Text="€1,200"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Pricing Notes"
               FontSize="14"
               FontWeight="SemiBold"
               Foreground="#374151"/>
                                <TextBox x:Name="PricingNotesTextBox"
             Height="100"
             Margin="0,8,0,0"
             FontSize="14"
             TextWrapping="Wrap"
             AcceptsReturn="True"
             VerticalScrollBarVisibility="Auto"
             Padding="12"/>
                            </StackPanel>
                            <!--STEP 5-->
                            <StackPanel x:Name="Step5Panel" Visibility="Collapsed">
                                <TextBlock Text="Step 5: Review"
               FontSize="24"
               FontWeight="Bold"
               Foreground="#1F2937"
               Margin="0,0,0,18"/>

                                <Border Background="#FAFBFF"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            CornerRadius="14"
            Padding="18"
            Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="Basic Information"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#1F2937"
                           Margin="0,0,0,12"/>

                                            <TextBlock Text="Package Name:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewPackageNameText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Trip Type:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewTripTypeText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Category:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewCategoryText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Description:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewDescriptionText"
                           FontSize="14"
                           Foreground="#374151"
                           TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Destination &amp; Dates"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#1F2937"
                           Margin="0,0,0,12"/>

                                            <TextBlock Text="Destination:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewDestinationText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Country:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewCountryText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Start Date:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewStartDateText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="End Date:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewEndDateText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Number of Days:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewNumberOfDaysText"
                           FontSize="14"
                           Foreground="#374151"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Background="#FAFBFF"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            CornerRadius="14"
            Padding="18"
            Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="Transport &amp; Accommodation"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#1F2937"
                           Margin="0,0,0,12"/>

                                            <TextBlock Text="Transport:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewTransportText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Departure City:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewDepartureCityText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Accommodation Type:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewAccommodationTypeText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Accommodation Name:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewAccommodationNameText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Meal Plan:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewMealPlanText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Available Seats:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewAvailableSeatsText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Included Services:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewServicesText"
                           FontSize="14"
                           Foreground="#374151"
                           TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Pricing Summary"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#1F2937"
                           Margin="0,0,0,12"/>

                                            <TextBlock Text="Base Price:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewBasePriceText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Discount:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewDiscountText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="VAT:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewVatText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Extra Charges:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewExtraChargesText"
                           FontSize="14"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                                            <TextBlock Text="Final Price:"
                           FontSize="14"
                           Foreground="#6B7280"/>
                                            <TextBlock x:Name="ReviewFinalPriceText"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#1F2937"
                           Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Background="#F3F8FF"
            CornerRadius="14"
            Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Ready to create package"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#1F2937"/>

                                        <TextBlock Text="Review the details above, then press Finish to create the travel package."
                       FontSize="14"
                       Foreground="#6B7280"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Bottom buttons -->
                <Grid Grid.Row="3" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Content="Save Draft"
                            Height="42"
                            Background="#F3F4F6"
                            Foreground="#1F2937"
                            BorderBrush="#D1D5DB"
                            FontWeight="SemiBold"/>

                    <Button x:Name="BackButton"
        Grid.Column="3"
        Content="Back"
        Height="42"
        Background="#E5E7EB"
        Foreground="#6B7280"
        BorderBrush="#D1D5DB"
        FontWeight="SemiBold"
        IsEnabled="False"
        Click="BackButton_Click"/>

                    <Button x:Name="NextButton"
        Grid.Column="5"
        Content="Next"
        Height="42"
        Background="#2F80ED"
        Foreground="White"
        BorderBrush="Transparent"
        FontWeight="SemiBold"
        Click="NextButton_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
