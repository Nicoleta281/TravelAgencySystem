<Window x:Class="TravelAgency.WPF.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Admin Dashboard"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#17335C">
            <DockPanel LastChildFill="True">

                <StackPanel DockPanel.Dock="Top" Margin="24,24,24,16">
                    <TextBlock Text="Travel Agency Admin"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="Administration Panel"
                               Foreground="#B8C7E0"
                               FontSize="14"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="16,10,16,0">
                    <Button Content="Dashboard"
                            Height="52"
                            Margin="0,0,0,10"
                            Background="#2563EB"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="16"
                            FontWeight="SemiBold"/>

                    <Button Content="User Management"
                            Height="52"
                            Margin="0,0,0,10"
                            Background="#21406D"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="15"/>

                    <Button Content="Role Management"
                            Height="52"
                            Margin="0,0,0,10"
                            Background="#21406D"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="15"/>

                    <Button Content="Bookings Control"
                            Height="52"
                            Margin="0,0,0,10"
                            Background="#21406D"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="15"/>

                    <Button Content="Analytics  Reports"
                            Height="52"
                            Margin="0,0,0,10"
                            Background="#21406D"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="15"/>

                    <Button Content="Financial Settings"
                            Height="52"
                            Margin="0,0,0,10"
                            Background="#21406D"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="15"/>

                    <Button Content="Package Moderation"
                            Height="52"
                            Margin="0,0,0,10"
                            Background="#21406D"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="15"/>
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Margin="16,20,16,20"
                        Padding="14"
                        CornerRadius="14"
                        Background="#21406D">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="48" Height="48" Fill="#DDE7F5"/>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Admin"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"/>
                            <TextBlock Text="System Administrator"
                                       Foreground="#C8D4E8"
                                       FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28">

                <!-- TOP BAR -->
                <DockPanel Margin="0,0,0,20">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Admin Dashboard"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"/>
                        <TextBlock Text="User access, analytics, moderation and financial control"
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
            Orientation="Horizontal"
            HorizontalAlignment="Right">
                        <Button Content="Refresh"
            Command="{Binding RefreshDashboardCommand}"
            Margin="0,0,10,0"
            Padding="16,8"
            Background="White"
            BorderBrush="#D6DCE5"/>

                        <Button Content="Settings"
            Margin="0,0,10,0"
            Padding="16,8"
            Background="White"
            BorderBrush="#D6DCE5"/>

                        <Button Content="Logout"
            Command="{Binding LogoutCommand}"
            Padding="16,8"
            Background="#FEF2F2"
            Foreground="#B91C1C"
            BorderBrush="#FECACA"/>
                    </StackPanel>
                </DockPanel>

                <!-- TOP STAT CARDS -->
                <UniformGrid Columns="4" Margin="0,0,0,22">
                    <Border Background="White" CornerRadius="16" Padding="18" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Total Users" FontSize="15" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding TotalUsersCount}"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="16" Padding="18" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Pending Bookings" FontSize="15" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding PendingBookingsCount}"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="16" Padding="18" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Monthly Revenue" FontSize="15" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding MonthlyRevenueText}"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="16" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Cancellation Rate" FontSize="15" Foreground="#6B7280"/>
                            <TextBlock Text="{Binding CancellationRateText}"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#DC2626"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- MAIN GRID -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*"/>
                        <ColumnDefinition Width="1.1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- USER MANAGEMENT -->
                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Background="White"
                            CornerRadius="18"
                            Padding="20"
                            Margin="0,0,18,18">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,16">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="User Management"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#1F2937"/>

                                <Button DockPanel.Dock="Right"
                                        Content="Manage Users"
                                        Padding="18,0"
                                        Background="#2563EB"
                                        Foreground="White"
                                        BorderBrush="Transparent" Height="29" Width="170"/>
                            </DockPanel>

                            <DataGrid ItemsSource="{Binding Users}"
                                      SelectedItem="{Binding SelectedUser}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      Height="280"
                                      BorderThickness="0"
                                      Background="White"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FBFD"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#E5E7EB"
                                      VerticalGridLinesBrush="#E5E7EB"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="User" Width="*" Binding="{Binding Username}"/>
                                    <DataGridTextColumn Header="Email" Width="1.4*" Binding="{Binding Email}"/>
                                    <DataGridTextColumn Header="Role" Width="*" Binding="{Binding Role}"/>
                                    <DataGridTextColumn Header="Status" Width="*" Binding="{Binding Status}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Content="Block selected user"
                                        Command="{Binding BlockUserCommand}"
                                        Margin="0,0,10,0"
                                        Padding="14,8"
                                        Background="#FEF2F2"
                                        Foreground="#B91C1C"
                                        BorderBrush="#FECACA"/>

                                <Button Content="Unblock selected user"
                                        Command="{Binding UnblockUserCommand}"
                                        Margin="0,0,10,0"
                                        Padding="14,8"
                                        Background="#ECFDF5"
                                        Foreground="#15803D"
                                        BorderBrush="#BBF7D0"/>

                                <Button Content="Change role"
                                        Command="{Binding ChangeRoleCommand}"
                                        Padding="14,8"
                                        Background="#EFF6FF"
                                        Foreground="#1D4ED8"
                                        BorderBrush="#BFDBFE"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ANALYTICS PANEL -->
                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Background="White"
                            CornerRadius="18"
                            Padding="20"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Analytics Overview"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#1F2937"/>

                            <StackPanel Margin="0,20,0,0">
                                <TextBlock Text="Top Destinations"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#374151"/>
                                <TextBlock Text="1. Paris"
                                           FontSize="15"
                                           Foreground="#6B7280"
                                           Margin="0,8,0,0"/>
                                <TextBlock Text="2. Rome"
                                           FontSize="15"
                                           Foreground="#6B7280"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="3. Bali"
                                           FontSize="15"
                                           Foreground="#6B7280"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <Separator Margin="0,18,0,18"/>

                            <StackPanel>
                                <TextBlock Text="User Status"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#374151"/>
                                <TextBlock Text="{Binding ActiveUsersCount, StringFormat=Active users: {0}}"
                                           Margin="0,10,0,0"
                                           FontSize="15"
                                           Foreground="#15803D"/>
                                <TextBlock Text="{Binding BlockedUsersCount, StringFormat=Blocked users: {0}}"
                                           Margin="0,6,0,0"
                                           FontSize="15"
                                           Foreground="#DC2626"/>
                            </StackPanel>

                            <Separator Margin="0,18,0,18"/>

                            <StackPanel>
                                <TextBlock Text="Occupancy Rate"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#374151"/>
                                <ProgressBar Value="78"
                                             Height="16"
                                             Margin="0,10,0,0"/>
                                <TextBlock Text="78%"
                                           HorizontalAlignment="Right"
                                           Margin="0,6,0,0"
                                           Foreground="#2563EB"
                                           FontWeight="Bold"/>
                            </StackPanel>

                            <Separator Margin="0,18,0,18"/>

                            <StackPanel>
                                <TextBlock Text="Cancellation Rate"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#374151"/>
                                <ProgressBar Value="{Binding CancellationRate}"
                                             Maximum="100"
                                             Height="16"
                                             Margin="0,10,0,0"/>
                                <TextBlock Text="{Binding CancellationRateText}"
                                           HorizontalAlignment="Right"
                                           Margin="0,6,0,0"
                                           Foreground="#DC2626"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- REVENUE / REPORTS -->
                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Background="White"
                            CornerRadius="18"
                            Padding="20"
                            Margin="0,0,18,18">
                        <StackPanel>
                            <TextBlock Text="Revenue and Reports"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#1F2937"/>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Revenue Trend"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="#374151"/>

                                    <Border Height="180"
                                            Margin="0,12,0,0"
                                            CornerRadius="14"
                                            Background="#EEF4FF"
                                            BorderBrush="#D7E3FF"
                                            BorderThickness="1">
                                        <Grid>
                                            <TextBlock Text="Monthly revenue chart"
                                                       Foreground="#6B7280"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="16"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="20,0,0,0" Width="200">
                                    <Border Background="#F9FAFB" CornerRadius="14" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Current Revenue"
                                                       FontSize="14"
                                                       Foreground="#6B7280"/>
                                            <TextBlock Text="{Binding MonthlyRevenueText}"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Foreground="#16A34A"
                                                       Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#F9FAFB" CornerRadius="14" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Cancellation Rate"
                                                       FontSize="14"
                                                       Foreground="#6B7280"/>
                                            <TextBlock Text="{Binding CancellationRateText}"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Foreground="#DC2626"
                                                       Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- PACKAGE MODERATION -->
                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Background="White"
                            CornerRadius="18"
                            Padding="20"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Package Moderation"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#1F2937"/>

                            <ListBox ItemsSource="{Binding PendingPackages}"
                                     SelectedItem="{Binding SelectedPackage}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Margin="0,18,0,0">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,12"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12"
                                                CornerRadius="14"
                                                Background="#F9FBFD"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="#111827"/>

                                                <TextBlock Text="{Binding Destination, StringFormat=Destination: {0}}"
                                                           Foreground="#6B7280"
                                                           Margin="0,6,0,0"/>

                                                <TextBlock Text="{Binding PeriodText, StringFormat=Period: {0}}"
                                                           Foreground="#6B7280"
                                                           Margin="0,4,0,0"/>

                                                <TextBlock Text="{Binding CreatedByAgent, StringFormat=Created by: {0}}"
                                                           Foreground="#6B7280"
                                                           Margin="0,4,0,0"/>

                                                <TextBlock Text="{Binding Status, StringFormat=Status: {0}}"
                                                           Foreground="#2563EB"
                                                           FontWeight="SemiBold"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Approve selected package"
                                        Command="{Binding ApprovePackageCommand}"
                                        Margin="0,0,10,0"
                                        Padding="14,8"
                                        Background="#DCFCE7"
                                        Foreground="#15803D"
                                        BorderBrush="#BBF7D0"/>

                                <Button Content="Reject selected package"
                                        Command="{Binding RejectPackageCommand}"
                                        Padding="14,8"
                                        Background="#FEE2E2"
                                        Foreground="#B91C1C"
                                        BorderBrush="#FECACA"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- FINANCIAL SETTINGS -->
                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Background="White"
                            CornerRadius="18"
                            Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="Financial Settings"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#1F2937"/>

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="VAT Rate:"
                                               VerticalAlignment="Center"
                                               FontSize="15"
                                               Margin="0,0,0,12"/>

                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Text="{Binding VatRate, UpdateSourceTrigger=PropertyChanged}"
                                             Height="34"
                                             Margin="0,0,0,12"/>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Global Discount:"
                                               VerticalAlignment="Center"
                                               FontSize="15"
                                               Margin="0,0,0,12"/>

                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding GlobalDiscount, UpdateSourceTrigger=PropertyChanged}"
                                             Height="34"
                                             Margin="0,0,0,12"/>

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="Currency:"
                                               VerticalAlignment="Center"
                                               FontSize="15"/>

                                    <ComboBox Grid.Row="2"
                                              Grid.Column="1"
                                              Height="34"
                                              ItemsSource="{Binding AvailableCurrencies}"
                                              SelectedItem="{Binding SelectedCurrency}"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Actions"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#1F2937"
                                           Margin="0,0,0,18"/>

                                <Button Content="Save Financial Settings"
                                        Command="{Binding SaveFinancialSettingsCommand}"
                                        Height="42"
                                        Margin="0,0,0,12"
                                        Background="#2563EB"
                                        Foreground="White"
                                        BorderBrush="Transparent"/>

                                <Button Content="Export Report"
                                        Height="42"
                                        Margin="0,0,0,12"
                                        Background="White"
                                        Foreground="#1F2937"
                                        BorderBrush="#D1D5DB"/>

                                <Button Content="View Detailed Analytics"
                                        Height="42"
                                        Background="White"
                                        Foreground="#1F2937"
                                        BorderBrush="#D1D5DB"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>