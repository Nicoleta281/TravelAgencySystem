<Window x:Class="TravelAgency.WPF.Views.AgentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Workspace"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7FB">

    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,0,0,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2B4C78"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1F3A5F">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Logo / Title -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse Width="52" Height="52" Fill="#2F80ED"/>
                    <TextBlock Text="Travel Agency"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="20,10,20,20">
                    <Button Content="Dashboard" Style="{StaticResource SidebarButtonStyle}" Background="#2F80ED"/>
                    <Button Content="Packages"
        Style="{StaticResource SidebarButtonStyle}"
        Command="{Binding ShowPackagesCommand}"/>

                    <Button Content="Bookings"
        Style="{StaticResource SidebarButtonStyle}"
        Command="{Binding ShowBookingsCommand}"/>
                    <Button Content="Clients" Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="Reports" Style="{StaticResource SidebarButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1"
      Margin="24"
      Visibility="{Binding PackagesVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="16"
                    Padding="24"
                    Margin="0,0,0,18" Grid.ColumnSpan="3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Travel Packages"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"/>
                        <TextBlock Text="Manage offers and bookings"
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Grid Grid.Column="1"
      Margin="16,0,16,0"
      VerticalAlignment="Center">
                        <TextBox x:Name="SearchBox"
             Height="42"
             Padding="14,0"
             VerticalContentAlignment="Center"
             FontSize="14"
             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Search packages..."
               Margin="14,0,0,0"
               VerticalAlignment="Center"
               Foreground="#9CA3AF"
               IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="2"
        Content="Create Package"
        Height="42"
        VerticalAlignment="Center"
        Background="#2F80ED"
        Foreground="White"
        FontWeight="SemiBold"
        BorderBrush="Transparent"
        Click="CreatePackage_Click"/>
                </Grid>
            </Border>

            <!-- Stats -->
            <Grid Grid.Row="1" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Packages" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding TotalPackagesCount}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Active Offers" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding ActiveOffersCount}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="White" CornerRadius="16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Average Price" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding AveragePriceText, StringFormat=€ {0}}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Background="White" CornerRadius="16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Value" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding TotalValueText, StringFormat=€ {0}}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main Area -->
            <Grid Grid.Row="2" Grid.ColumnSpan="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left section -->
                <Border Grid.Column="0"
        Background="White"
        CornerRadius="16"
        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                   Text="Recent Packages"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#1F2937"
                   Margin="0,0,0,16"/>

                        <ListBox Grid.Row="1"
                 ItemsSource="{Binding TripsView}"
                 SelectedItem="{Binding SelectedTrip, Mode=TwoWay}"
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 HorizontalContentAlignment="Stretch"
     
                                 >

                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,12,12"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="OuterBorder"
                                        Background="Transparent"
                                        CornerRadius="14">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="OuterBorder" Property="Background" Value="#EAF2FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="200"
                            Background="#FAFBFF"
                            CornerRadius="14"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1">
                                        <StackPanel>
                                            <Border Height="95"
                                    Background="#DCEBFA"
                                    CornerRadius="14,14,0,0">
                                                <Grid>
                                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#1F3A5F"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="10"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Margin="12">
                                                <TextBlock Text="{Binding Name}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#1F2937"
                                           TextWrapping="Wrap"/>

                                                <TextBlock Margin="0,4,0,3"
                                           FontSize="12"
                                           Foreground="#6B7280">
                                    <Run Text="{Binding TransportName, Mode=OneWay}"/>
                                    <Run Text=" + "/>
                                    <Run Text="{Binding StayName, Mode=OneWay}"/>
                                                </TextBlock>

                                                <TextBlock Margin="0,0,0,8"
                                           FontSize="12"
                                           Foreground="#6B7280">
                                    <Run Text="Days: "/>
                                    <Run Text="{Binding DaysCount, Mode=OneWay}"/>
                                                </TextBlock>

                                                <Border Background="#E5EDFF"
                                        CornerRadius="8"
                                        Padding="6,3"
                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Season.Name, TargetNullValue=Trip}"
                                               Foreground="#2F5BD1"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                                </Border>

                                                <TextBlock Text="{Binding Price, StringFormat=€ {0:F2}}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#1F2937"
                                           Margin="0,14,0,12"/>

                                                <Button Content="View Details"
                                        Height="32"
                                        Background="#2F80ED"
                                        Foreground="White"
                                        BorderBrush="Transparent"
                                        FontWeight="SemiBold"
                                        IsHitTestVisible="False"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Grid.Row="1"
                   Text="No packages found"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#9CA3AF"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TripsView.IsEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Grid Grid.Column="1"
      Margin="24"
      Visibility="{Binding BookingsVisibility}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
            Background="White"
            CornerRadius="16"
            Padding="24"
            Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock Text="Booking Requests"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1F2937"/>
                                    <TextBlock Text="Review and manage pending booking requests"
                       FontSize="14"
                       Foreground="#6B7280"
                       Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
            Background="White"
            CornerRadius="16"
            Padding="20">
                                <ListBox ItemsSource="{Binding PendingBookings}"
                 SelectedItem="{Binding SelectedBooking}"
                 BorderThickness="0"
                 Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12"
                            Padding="14"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="12"
                            Background="#FAFBFF">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding TripPackage.Name}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#1F2937"/>

                                                    <TextBlock Margin="0,6,0,0">
                                <Run Text="Client: "/>
                                <Run Text="{Binding Client.Username}"/>
                                                    </TextBlock>

                                                    <TextBlock Margin="0,4,0,0">
                                <Run Text="Booked on: "/>
                                <Run Text="{Binding BookingDate, StringFormat={}{0:dd MMM yyyy HH:mm}}"/>
                                                    </TextBlock>

                                                    <TextBlock Margin="0,4,0,0">
                                <Run Text="Status: "/>
                                <Run Text="{Binding Status.Name}"/>
                                                    </TextBlock>

                                                    <TextBlock Margin="0,4,0,0">
                                <Run Text="Base Price: € "/>
                                <Run Text="{Binding BasePrice, StringFormat={}{0:F2}}"/>
                                                    </TextBlock>

                                                    <TextBlock Margin="0,4,0,0">
                                <Run Text="Total Price: € "/>
                                <Run Text="{Binding TotalPrice, StringFormat={}{0:F2}}"/>
                                                    </TextBlock>

                                                    <ItemsControl ItemsSource="{Binding SelectedExtras}" Margin="0,8,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#E5EDFF"
                                                CornerRadius="8"
                                                Padding="8,4"
                                                Margin="0,0,0,6"
                                                HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding}"
                                                       Foreground="#2F5BD1"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,18,0,0">
                                <Button Content="Refresh"
                Width="110"
                Height="40"
                Margin="0,0,12,0"
                Command="{Binding RefreshPendingBookingsCommand}"/>

                                <Button Content="Approve"
                Width="110"
                Height="40"
                Margin="0,0,12,0"
                Background="#2F80ED"
                Foreground="White"
                BorderBrush="Transparent"
                FontWeight="SemiBold"
                Command="{Binding ApproveBookingCommand}"/>

                                <Button Content="Reject"
                Width="110"
                Height="40"
                Background="#E74C3C"
                Foreground="White"
                BorderBrush="Transparent"
                FontWeight="SemiBold"
                Command="{Binding RejectBookingCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                <!-- Right section -->
                <Border Grid.Column="2"
        Background="White"
        CornerRadius="16"
        Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="#F8FAFC"
        BorderBrush="#E5E7EB"
        BorderThickness="1"
        CornerRadius="14"
        Padding="24"
        Margin="0,0,0,16">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTrip}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="No package selected"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#1F2937"
                   HorizontalAlignment="Center"/>
                                    <TextBlock Text="Select a package from the list to see its details here."
                   FontSize="14"
                   Foreground="#6B7280"
                   Margin="0,8,0,0"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Width="250"/>
                                </StackPanel>
                            </Border>


                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTrip}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>


                                <!-- Top banner -->
                            <Border Height="170"
                    Background="#DCEBFA"
                    CornerRadius="14"
                    Margin="0,0,0,18">
                                <Grid>
                                    <TextBlock Text="{Binding SelectedTrip.Name, TargetNullValue=NO PACKAGE}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#1F3A5F"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="12"/>
                                </Grid>
                            </Border>

                            <!-- Title -->
                            <TextBlock Text="{Binding SelectedTrip.Name, TargetNullValue=No package selected}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1F2937"/>

                            <TextBlock Text="{Binding SelectedTrip.Season.Name, TargetNullValue=No season}"
                       FontSize="15"
                       Foreground="#6B7280"
                       Margin="0,6,0,16"/>

                            <!-- Price -->
                            <Border Background="#F3F8FF"
                    CornerRadius="12"
                    Padding="14"
                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Price"
                               FontSize="14"
                               Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding SelectedTrip.Price, StringFormat=€ {0:F2}, TargetNullValue=-}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Details -->
                            <Border Background="#FAFBFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14"
                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Package Details"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Margin="0,0,0,12"/>

                                    <TextBlock Margin="0,0,0,8">
                        <Run Text="Transport: "/>
                        <Run Text="{Binding SelectedTrip.TransportName, Mode=OneWay, TargetNullValue=N/A}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,8">
                        <Run Text="Stay: "/>
                        <Run Text="{Binding SelectedTrip.StayName, Mode=OneWay, TargetNullValue=N/A}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,8">
                        <Run Text="Season: "/>
                        <Run Text="{Binding SelectedTrip.Season.Name, TargetNullValue=N/A}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,8">
                        <Run Text="Start Date: "/>
                        <Run Text="{Binding SelectedTrip.Season.StartDate, StringFormat={}{0:dd MMM yyyy}, TargetNullValue=-}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,8">
                        <Run Text="End Date: "/>
                        <Run Text="{Binding SelectedTrip.Season.EndDate, StringFormat={}{0:dd MMM yyyy}, TargetNullValue=-}"/>
                                    </TextBlock>

                                    <TextBlock>
                        <Run Text="Days Count: "/>
                        <Run Text="{Binding SelectedTrip.DaysCount, Mode=OneWay, TargetNullValue=0}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Extra services -->
                            <Border Background="#FAFBFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14"
                    Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Extra Services"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Margin="0,0,0,10"/>

                                    <ItemsControl ItemsSource="{Binding SelectedTrip.ExtraServiceNames}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#E5EDFF"
                                        CornerRadius="8"
                                        Padding="8,4"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding}"
                                               Foreground="#2F5BD1"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="No extra services"
                               Foreground="#6B7280">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTrip.ExtraServices.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedTrip}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
            Content="Edit"
            Height="40"
            Background="#F3F4F6"
            Foreground="#1F2937"
            BorderBrush="#D1D5DB"
            FontWeight="SemiBold"
            Click="EditPackage_Click"/>

                                <Button Grid.Column="2"
            Content="Clone"
            Height="40"
            Background="#2F80ED"
            Foreground="White"
            BorderBrush="Transparent"
            FontWeight="SemiBold"
            Command="{Binding CloneCommand}"/>

                                <Button Grid.Column="4"
            Content="Delete"
            Height="40"
            Background="#E74C3C"
            Foreground="White"
            BorderBrush="Transparent"
            FontWeight="SemiBold"
            Command="{Binding DeleteCommand}"/>
                            </Grid>
                        </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>