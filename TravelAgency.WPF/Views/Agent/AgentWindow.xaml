<Window x:Class="TravelAgency.WPF.Views.AgentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Workspace"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F6F7FB">

    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,0,0,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2B4C78"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1F3A5F">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Logo / Title -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse Width="52" Height="52" Fill="#2F80ED"/>
                    <TextBlock Text="Travel Agency"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="20,10,20,20">
                    <Button Content="Dashboard"
            Style="{StaticResource SidebarButtonStyle}"
            Background="#2F80ED"
            Command="{Binding ShowPackagesCommand}"/>

                    <Button Content="Packages"
            Style="{StaticResource SidebarButtonStyle}"
            Command="{Binding ShowPackagesCommand}"/>

                    <Button Content="Bookings"
            Style="{StaticResource SidebarButtonStyle}"
            Command="{Binding ShowBookingsCommand}"/>

                    <Button Content="Clients"
            Style="{StaticResource SidebarButtonStyle}"/>

                    <Button Content="Reports"
            Style="{StaticResource SidebarButtonStyle}"
            Command="{Binding ShowReportsCommand}"/>

                    <Button Content="Logout"
            Command="{Binding LogoutCommand}"
            Background="#EF4444"
            Foreground="White"
            Margin="0,20,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
       
        <!-- Main Content -->
        <Grid Grid.Column="1"
      Margin="24"
      Visibility="{Binding PackagesVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="16"
                    Padding="24"
                    Margin="0,0,0,18" Grid.ColumnSpan="3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Travel Packages"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"/>
                        <TextBlock Text="Manage offers and bookings"
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Grid Grid.Column="1"
      Margin="16,0,16,0"
      VerticalAlignment="Center">
                        <TextBox x:Name="SearchBox"
             Height="42"
             Padding="14,0"
             VerticalContentAlignment="Center"
             FontSize="14"
             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Search packages..."
               Margin="14,0,0,0"
               VerticalAlignment="Center"
               Foreground="#9CA3AF"
               IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="2"
        Content="Create Package"
        Height="42"
        VerticalAlignment="Center"
        Background="#2F80ED"
        Foreground="White"
        FontWeight="SemiBold"
        BorderBrush="Transparent"
        Click="CreatePackage_Click"/>
                </Grid>
            </Border>

            <!-- Stats -->
            <Grid Grid.Row="1" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Packages" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding TotalPackagesCount}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Active Offers" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding ActiveOffersCount}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="White" CornerRadius="16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Average Price" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding AveragePriceText, StringFormat=€ {0}}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Background="White" CornerRadius="16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Value" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding TotalValueText, StringFormat=€ {0}}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main Area -->
            
            <Grid Grid.Row="2" Grid.ColumnSpan="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="197*"/>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="86*"/>
                </Grid.ColumnDefinitions>

                <!-- Left section -->
                <Grid Margin="0,20,0,0" HorizontalAlignment="Left" Width="777">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="125*"/>
                        <ColumnDefinition Width="134*"/>
                        <ColumnDefinition Width="0*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: RECENT PACKAGES -->
                    <Border
            Background="White"
            CornerRadius="16"
            Padding="20" HorizontalAlignment="Center" Width="375">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="246*"/>
                                <ColumnDefinition Width="49*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Recent Packages"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,0,0,16" Grid.ColumnSpan="2"/>

                            <ListBox
                     ItemsSource="{Binding TripsView}"
                     SelectedItem="{Binding SelectedTrip, Mode=TwoWay}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     HorizontalContentAlignment="Stretch" Grid.ColumnSpan="2" Margin="0,45,0,0" Grid.RowSpan="2">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,12,12"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="OuterBorder"
                                            Background="Transparent"
                                            CornerRadius="14">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="OuterBorder" Property="Background" Value="#EAF2FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="210"
                                Background="#FAFBFF"
                                CornerRadius="14"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1">
                                            <StackPanel>
                                                <Border Height="95"
                                        Background="#DCEBFA"
                                        CornerRadius="14,14,0,0"/>

                                                <StackPanel Margin="12">
                                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#1F2937"
                                               TextWrapping="Wrap"/>

                                                    <TextBlock Text="{Binding TransportName, StringFormat=Transport: {0}}"
                                               Margin="0,4,0,2"
                                               FontSize="12"
                                               Foreground="#6B7280"/>

                                                    <TextBlock Text="{Binding StayName, StringFormat=Stay: {0}}"
                                               Margin="0,0,0,6"
                                               FontSize="12"
                                               Foreground="#6B7280"/>

                                                    <TextBlock Text="{Binding Price, StringFormat=€ {0:F2}}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#1F2937"
                                               Margin="0,8,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- MIDDLE: BOOKING REQUESTS -->
                    <Border Grid.Column="1"
            Background="White"
            CornerRadius="16"
            Padding="20"
            Margin="10,0,4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="122*"/>
                                <ColumnDefinition Width="137*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="41.62"/>
                                <RowDefinition Height="28.263"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,0,16" Grid.RowSpan="2" Grid.ColumnSpan="2">
                                <TextBlock Text="Booking Requests"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#1F2937"/>
                                <TextBlock Text="Review and manage pending bookings"
                           FontSize="14"
                           Foreground="#6B7280"
                           Margin="0,6,0,0"/>
                            </StackPanel>

                            <ListBox Grid.Row="2"
                     ItemsSource="{Binding PendingBookings}"
                     SelectedItem="{Binding SelectedBooking, Mode=TwoWay}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     HorizontalContentAlignment="Stretch" Margin="0,0,0,58" Grid.RowSpan="2" Grid.ColumnSpan="2">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,12"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="OuterBorder"
                                            Background="Transparent"
                                            CornerRadius="12">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="OuterBorder" Property="Background" Value="#EAF2FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="12"
                                Background="#FAFBFF">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TripPackage.Name}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#1F2937"/>

                                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding Client.Username, StringFormat=Client: {0}}"
                                           Foreground="#374151"/>

                                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding BookingDate, StringFormat=Booked on: {0:dd MMM yyyy HH:mm}}"
                                           Foreground="#374151"/>

                                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding Status.Name, StringFormat=Status: {0}}"
                                           Foreground="#374151"/>

                                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding TotalPrice, StringFormat=Total Price: € {0:F2}}"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2937"/>

                                                <ItemsControl ItemsSource="{Binding SelectedExtras}"
                                              Margin="0,10,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#E5EDFF"
                                                    CornerRadius="8"
                                                    Padding="8,4"
                                                    Margin="0,0,8,8"
                                                    HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding}"
                                                           Foreground="#2F5BD1"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid Grid.Row="3" Margin="0,16,0,0" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                        Content="Refresh"
                        Height="42"
                        Background="#F3F4F6"
                        Foreground="#1F2937"
                        BorderBrush="#D1D5DB"
                        FontWeight="SemiBold"
                        Command="{Binding RefreshPendingBookingsCommand}"/>

                                <Button Grid.Column="2"
                        Content="Approve"
                        Height="42"
                        Background="#2F80ED"
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontWeight="SemiBold"
                        Command="{Binding ApproveBookingCommand}"/>

                                <Button Grid.Column="4"
                        Content="Reject"
                        Height="42"
                        Background="#E74C3C"
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontWeight="SemiBold"
                        Command="{Binding RejectBookingCommand}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
                <!-- Right section -->
                <Border Grid.Column="2"
        Background="White"
        CornerRadius="16"
        Padding="20" HorizontalAlignment="Left" Width="345" Margin="10,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="#F8FAFC"
        BorderBrush="#E5E7EB"
        BorderThickness="1"
        CornerRadius="14"
        Padding="24"
        Margin="0,0,0,16" Height="104" Width="284">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTrip}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="No package selected"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#1F2937"
                   HorizontalAlignment="Center"/>
                                    <TextBlock Text="Select a package from the list to see its details here."
                   FontSize="14"
                   Foreground="#6B7280"
                   Margin="0,8,0,0"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Width="250"/>
                                </StackPanel>
                            </Border>


                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTrip}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>


                                <!-- Top banner -->
                                <Border Height="170"
                    Background="#DCEBFA"
                    CornerRadius="14"
                    Margin="0,0,0,18">
                                    <Grid>
                                        <TextBlock Text="{Binding SelectedTrip.Name, TargetNullValue=NO PACKAGE}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#1F3A5F"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="12"/>
                                    </Grid>
                                </Border>

                                <!-- Title -->
                                <TextBlock Text="{Binding SelectedTrip.Name, TargetNullValue=No package selected}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1F2937"/>

                                <TextBlock Text="{Binding SelectedTrip.Season.Name, TargetNullValue=No season}"
                       FontSize="15"
                       Foreground="#6B7280"
                       Margin="0,6,0,16"/>

                                <!-- Price -->
                                <Border Background="#F3F8FF"
                    CornerRadius="12"
                    Padding="14"
                    Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Price"
                               FontSize="14"
                               Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding SelectedTrip.Price, StringFormat=€ {0:F2}, TargetNullValue=-}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Details -->
                                <Border Background="#FAFBFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14"
                    Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Package Details"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Margin="0,0,0,12"/>

                                        <TextBlock Margin="0,0,0,8">
                        <Run Text="Transport: "/>
                        <Run Text="{Binding SelectedTrip.TransportName, Mode=OneWay, TargetNullValue=N/A}"/>
                                        </TextBlock>

                                        <TextBlock Margin="0,0,0,8">
                        <Run Text="Stay: "/>
                        <Run Text="{Binding SelectedTrip.StayName, Mode=OneWay, TargetNullValue=N/A}"/>
                                        </TextBlock>

                                        <TextBlock Margin="0,0,0,8">
                        <Run Text="Season: "/>
                        <Run Text="{Binding SelectedTrip.Season.Name, TargetNullValue=N/A}"/>
                                        </TextBlock>

                                        <TextBlock Margin="0,0,0,8">
                        <Run Text="Start Date: "/>
                        <Run Text="{Binding SelectedTrip.Season.StartDate, StringFormat={}{0:dd MMM yyyy}, TargetNullValue=-}"/>
                                        </TextBlock>

                                        <TextBlock Margin="0,0,0,8">
                        <Run Text="End Date: "/>
                        <Run Text="{Binding SelectedTrip.Season.EndDate, StringFormat={}{0:dd MMM yyyy}, TargetNullValue=-}"/>
                                        </TextBlock>

                                        <TextBlock>
                        <Run Text="Days Count: "/>
                        <Run Text="{Binding SelectedTrip.DaysCount, Mode=OneWay, TargetNullValue=0}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Extra services -->
                                <Border Background="#FAFBFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14"
                    Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="Extra Services"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Margin="0,0,0,10"/>

                                        <ItemsControl ItemsSource="{Binding SelectedTrip.ExtraServiceNames}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#E5EDFF"
                                        CornerRadius="8"
                                        Padding="8,4"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding}"
                                               Foreground="#2F5BD1"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="No extra services"
                               Foreground="#6B7280">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedTrip.ExtraServices.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedTrip}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
            Content="Edit"
            Height="40"
            Background="#F3F4F6"
            Foreground="#1F2937"
            BorderBrush="#D1D5DB"
            FontWeight="SemiBold"
            Click="EditPackage_Click"/>

                                    <Button Grid.Column="2"
            Content="Clone"
            Height="40"
            Background="#2F80ED"
            Foreground="White"
            BorderBrush="Transparent"
            FontWeight="SemiBold"
            Command="{Binding CloneCommand}"/>

                                    <Button Grid.Column="4"
            Content="Delete"
            Height="40"
            Background="#E74C3C"
            Foreground="White"
            BorderBrush="Transparent"
            FontWeight="SemiBold"
            Command="{Binding DeleteCommand}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- REPORTS -->
        <Grid Grid.Column="1"
      Margin="24"
      Visibility="{Binding ReportsVisibility}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
            Background="White"
            CornerRadius="16"
            Padding="24">
                <StackPanel>
                    <TextBlock Text="Generate Reports"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1F2937"/>

                    <TextBlock Text="Export booking reports in PDF, CSV or TXT format"
                       FontSize="14"
                       Foreground="#6B7280"
                       Margin="0,6,0,20"/>

                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="250"
                          Height="40"
                          Margin="0,0,12,0"
                          ItemsSource="{Binding ReportTypes}"
                          SelectedItem="{Binding SelectedReportType}"/>

                        <ComboBox Width="140"
                          Height="40"
                          Margin="0,0,12,0"
                          ItemsSource="{Binding ExportFormats}"
                          SelectedItem="{Binding SelectedExportFormat}"/>

                        <Button Content="Generate"
                        Width="120"
                        Height="40"
                        Background="#2F80ED"
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontWeight="SemiBold"
                        Command="{Binding GenerateReportCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
            Background="White"
            CornerRadius="16"
            Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Pending Bookings Preview"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#1F2937"/>

                        <TextBlock Text="These are the booking requests currently loaded for report generation"
                           FontSize="14"
                           Foreground="#6B7280"
                           Margin="0,6,0,18"/>
                    </StackPanel>

                    <ListBox Grid.Row="1"
                     ItemsSource="{Binding PendingBookings}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     HorizontalContentAlignment="Stretch">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,12"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="12"
                                Background="#FAFBFF">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TripPackage.Name}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#1F2937"/>

                                        <TextBlock Margin="0,8,0,0"
                                           Text="{Binding Client.Username, StringFormat=Client: {0}}"
                                           Foreground="#374151"/>

                                        <TextBlock Margin="0,4,0,0"
                                           Text="{Binding BookingDate, StringFormat=Booked on: {0:dd MMM yyyy HH:mm}}"
                                           Foreground="#374151"/>

                                        <TextBlock Margin="0,4,0,0"
                                           Text="{Binding Status.Name, StringFormat=Status: {0}}"
                                           Foreground="#374151"/>

                                        <TextBlock Margin="0,4,0,0"
                                           Text="{Binding TotalPrice, StringFormat=Total Price: € {0:F2}}"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2937"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>